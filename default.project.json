{
  "name": "Pressure Washing Simulator Roblox",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },

      "Remotes": {
        "$className": "Folder",
        "CleanSegmentRequest": {
          "$className": "RemoteEvent"
        },
        "AcceptJobRequest": {
          "$className": "RemoteEvent"
        },
        "QuitJobRequest": {
          "$className": "RemoteEvent"
        },
        "JobStateChanged": {
          "$className": "RemoteEvent"
        },
        "RespawnVehicleRequest": {
          "$className": "RemoteEvent"
        },
        "PurchaseItemRequest": {
          "$className": "RemoteEvent"
        },
        "EquipItemRequest": {
          "$className": "RemoteEvent"
        },
        "PurchaseTankRequest": {
          "$className": "RemoteEvent"
        },
        "HatchEggRequest": {
          "$className": "RemoteEvent"
        },
        "PetHatched": {
          "$className": "RemoteEvent"
        },
        "EquipPetRequest": {
          "$className": "RemoteEvent"
        },
        "PetInventoryChanged": {
          "$className": "RemoteEvent"
        },
        "PetInventoryRequest": {
          "$className": "RemoteEvent"
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
