{
  "name": "Pressure Washing Simulator Roblox",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Washers": {
        "$className": "Folder"
      },
      "Shared": {
        "$path": "src/shared"
      },

      "Remotes": {
        "$className": "Folder",
        "CleanSegmentRequest": {
          "$className": "RemoteEvent"
        },
        "SprayWaterRequest": {
          "$className": "RemoteEvent"
        },
        "AcceptJobRequest": {
          "$className": "RemoteEvent"
        },
        "QuitJobRequest": {
          "$className": "RemoteEvent"
        },
        "JobStateChanged": {
          "$className": "RemoteEvent"
        },
        "PurchaseItemRequest": {
          "$className": "RemoteEvent"
        },
        "EquipItemRequest": {
          "$className": "RemoteEvent"
        },
        "PurchaseTankRequest": {
          "$className": "RemoteEvent"
        },
        "HatchEggRequest": {
          "$className": "RemoteEvent"
        },
        "PetHatched": {
          "$className": "RemoteEvent"
        },
        "EquipPetRequest": {
          "$className": "RemoteEvent"
        },
        "PetInventoryChanged": {
          "$className": "RemoteEvent"
        },
        "PetInventoryRequest": {
          "$className": "RemoteEvent"
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "EnvironmentFixtures": {
        "$className": "Folder"
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
