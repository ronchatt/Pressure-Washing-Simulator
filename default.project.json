{
  "name": "Pressure Washing Simulator Roblox",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Washers": {
        "$className": "Folder"
      },
      "Vehicles": {
        "$className": "Folder"
      },
      "Shared": {
        "$path": "src/shared"
      },

      "Remotes": {
        "$className": "Folder",
        "CleanSegmentRequest": {
          "$className": "RemoteEvent"
        },
        "SprayWaterRequest": {
          "$className": "RemoteEvent"
        },
        "AcceptJobRequest": {
          "$className": "RemoteEvent"
        },
        "QuitJobRequest": {
          "$className": "RemoteEvent"
        },
        "JobStateChanged": {
          "$className": "RemoteEvent"
        },
        "JobStateRequest": {
          "$className": "RemoteEvent"
        },
        "TutorialStateRequest": {
          "$className": "RemoteEvent"
        },
        "TutorialStateChanged": {
          "$className": "RemoteEvent"
        },
        "TutorialCompleteRequest": {
          "$className": "RemoteEvent"
        },
        "PurchaseItemRequest": {
          "$className": "RemoteEvent"
        },
        "EquipItemRequest": {
          "$className": "RemoteEvent"
        },
        "PurchaseTankRequest": {
          "$className": "RemoteEvent"
        },
        "ShopStateRequest": {
          "$className": "RemoteEvent"
        },
        "ShopStateChanged": {
          "$className": "RemoteEvent"
        },
        "WaterRefillRequest": {
          "$className": "RemoteEvent"
        },
        "WaterRefillResult": {
          "$className": "RemoteEvent"
        },
        "HatchEggRequest": {
          "$className": "RemoteEvent"
        },
        "PetHatched": {
          "$className": "RemoteEvent"
        },
        "EquipPetRequest": {
          "$className": "RemoteEvent"
        },
        "PetInventoryChanged": {
          "$className": "RemoteEvent"
        },
        "PetInventoryRequest": {
          "$className": "RemoteEvent"
        },
        "SprintStateRequest": {
          "$className": "RemoteEvent"
        },
        "RespawnVehicleRequest": {
          "$className": "RemoteEvent"
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [0.3882353, 0.4745098, 0.2235294],
          "Locked": true,
          "Material": "Grass",
          "Position": [0, -10, 0],
          "Size": [2048, 20, 2048]
        }
      },
      "EnvironmentFixtures": {
        "$className": "Folder"
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
